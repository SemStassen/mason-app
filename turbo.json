{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "**/.env*"
  ],
  "ui": "tui",
  "tasks": {
    "db:export": {
      "inputs": [
        "src/db/schema.ts"
      ],
      "outputs": [
        "src/db/schema.sql",
        "src/db/schema-hash.ts"
      ]
    },
    "build": {
      "dependsOn": [
        "^build",
        "db:export"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": [
        "db:export"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^typecheck"
      ]
    },
    "clean": {
      "cache": false
    }
  }
}
