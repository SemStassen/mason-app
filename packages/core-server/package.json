{
  "name": "@recount/core-server",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf node_modules dist .turbo tsconfig.tsbuildinfo",
    "format": "oxfmt --write .",
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@recount/auth": "workspace:*",
    "@recount/core": "workspace:*",
    "@recount/db": "workspace:*",
    "@recount/notifications": "workspace:*",
    "drizzle-orm": "catalog:",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@recount/config": "workspace:*",
    "typescript": "catalog:dev"
  },
  "imports": {
    "#shared/*": "./src/shared/*.ts"
  },
  "exports": {
    "./infra/*": "./src/infra/*/index.ts",
    "./modules/*": "./src/modules/*/index.ts",
    "./shared/*": "./src/shared/*/index.ts"
  }
}
