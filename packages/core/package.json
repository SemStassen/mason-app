{
  "name": "@mason/core",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf node_modules dist .turbo tsconfig.tsbuildinfo",
    "format": "oxfmt --write .",
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "effect": "catalog:",
    "uuid": "catalog:"
  },
  "devDependencies": {
    "@mason/config": "workspace:*",
    "typescript": "catalog:dev"
  },
  "imports": {
    "#api/*": "./src/api/*.ts",
    "#modules/*": "./src/modules/*.ts",
    "#shared/*": "./src/shared/*.ts"
  },
  "exports": {
    "./contracts": "./src/api/contracts/index.ts",
    "./rpc": "./src/api/rpc/index.ts",
    "./flows/*": "./src/flows/*/index.ts",
    "./modules/*": "./src/modules/*/index.ts",
    "./shared/*": "./src/shared/*/index.ts"
  }
}
