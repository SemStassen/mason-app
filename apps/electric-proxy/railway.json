{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "watchPatterns": [
      "apps/electric-proxy/**",
      "packages/**",
      "package.json",
      "bun.lock",
      "turbo.json"
    ]
  },
  "deploy": {
    "startCommand": "bun run apps/electric-proxy/src/index.ts",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ALWAYS"
  }
}
