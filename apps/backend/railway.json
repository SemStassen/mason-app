{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "turbo build --filter=@recount/backend",
    "watchPatterns": [
      "apps/backend/**",
      "packages/**",
      "package.json",
      "bun.lock",
      "turbo.json"
    ]
  },
  "deploy": {
    "startCommand": "bun run apps/backend/src/index.ts",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ALWAYS"
  }
}
