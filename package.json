{
  "name": "mason",
  "packageManager": "bun@1.3.0",
  "scripts": {
    "build": "turbo build",
    "clean": "turbo clean --parallel && rm -rf .turbo/cache node_modules",
    "dev": "turbo dev --parallel",
    "docker:up": "docker compose -f ./docker-compose.yml up -d",
    "format": "biome format --write .",
    "lint": "turbo lint && manypkg check",
    "typecheck": "turbo typecheck",
    "subtree:create:effect": "git remote add effect https://github.com/Effect-TS/effect-smol && git subtree add --prefix=.better-agents/effect effect main --squash",
    "subtree:update:effect": "git subtree pull --prefix=.better-agents/effect effect main --squash"
  },
  "private": true,
  "workspaces": {
    "packages": [
      "interface",
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "drizzle-orm": "^1.0.0-beta.16-ea816b6",
      "effect": "^4.0.0-beta.31"
    },
    "catalogs": {
      "dev": {
        "@tailwindcss/vite": "^4.1.17",
        "@types/react": "^19.2.2",
        "@types/react-dom": "^19.2.1",
        "@vitejs/plugin-react": "^5.0.4",
        "babel-plugin-react-compiler": "^1.0.0",
        "drizzle-kit": "^1.0.0-beta.16-ea816b6",
        "typescript": "^5.9.3",
        "vite": "^7.2.2",
        "vite-tsconfig-paths": "^5.1.4"
      },
      "frontend": {
        "@base-ui-components/react": "^1.0.0-beta.4",
        "@tanstack/react-form": "^1.23.0",
        "drizzle-orm": "^0.44.4",
        "react": "^19.2.0",
        "react-dom": "^19.2.0"
      }
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@effect/language-service": "^0.80.0",
    "@effect/vitest": "^0.27.0",
    "lefthook": "^2.1.4",
    "turbo": "^2.8.16",
    "typescript": "catalog:dev",
    "ultracite": "7.3.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {}
}
